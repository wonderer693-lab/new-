      }
    ],
    "common_use_cases": [
      "Sync contacts from HubSpot to email marketing platform",
      "Create deals automatically from form submissions"
    ],
    "community_constraints": [
      {
        "source": "StackOverflow",
        "issue": "High latency on /crm/v3/objects/contacts search endpoint",
        "frequency": "high",
        "workaround": "Use batch GET by ID instead of search when possible"
      }
    ],
    "last_crawled": "2026-06-26",
    "data_quality_score": null
  },

  "integration_schema": {
    "integration_id": "hubspot_to_mailchimp",
    "tool_a": {
      "tool_id": "hubspot",
      "tool_name": "HubSpot",
      "endpoints_involved": [
        {"endpoint": "/crm/v3/objects/contacts", "method": "GET", "purpose": "Fetch contacts to sync"}
      ]
    },
    "tool_b": {
      "tool_id": "mailchimp",
      "tool_name": "Mailchimp",
      "endpoints_involved": [
        {"endpoint": "/3.0/lists/{list_id}/members", "method": "POST", "purpose": "Add/update contact as list member"}
      ]
    },
    "sync_type": "Unidirectional / Bi-directional",
    "common_use_cases": [
      "Automatically add HubSpot contacts to Mailchimp audience list",
      "Tag Mailchimp subscribers based on HubSpot deal stage"
    ],
    "edge_cases_and_errors": [
      {
        "error_code": "422",
        "error_tool": "Mailchimp",
        "cause": "HubSpot contact email missing or malformed",
        "solution": "Add email validation before sending to Mailchimp API",
        "source": "StackOverflow"
      }
    ],
    "authentication_flow": "OAuth 2.0 for both services; requires token refresh handling",
    "community_solutions": [
      {
        "problem": "Duplicate contacts when syncing bidirectionally",
        "solution": "Use Mailchimp's merge_fields with HubSpot ID as the unique identifier to prevent duplicates",
        "source": "GitHub issue #142 - hubspot-mailchimp-sync"
      }
    ]
  }
