---
import '../styles/global.css';

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    noindex?: boolean;
    keywords?: string[];
    author?: string;
    lastUpdated?: string;
    pageType?: string;
  };
}
const { frontmatter } = Astro.props;
const url = Astro.url;
const canonical = frontmatter.canonical || url.href;
const pageType = frontmatter.pageType || '';
const defaultOgImage = pageType.includes('error') ? '/og-error.svg' 
  : pageType.includes('integration') ? '/og-integration.svg'
  : pageType.includes('migration') ? '/og-migration.svg'
  : pageType.includes('tool') ? '/og-tool.svg'
  : '/og-default.svg';
const ogImage = frontmatter.ogImage || `${url.origin}${defaultOgImage}`;
const keywords = frontmatter.keywords?.join(', ') || '';
const isContent = frontmatter.lastUpdated !== undefined;
const robotsDirective = frontmatter.noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{frontmatter.title}</title>
  <meta name="description" content={frontmatter.description} />
  <meta name="robots" content={robotsDirective} />
  {keywords && <meta name="keywords" content={keywords} />}
  <!-- Google Search Console verification — replace content value with your GSC verification code -->
  <meta name="google-site-verification" content="REPLACE_WITH_GSC_VERIFICATION_CODE" />
  {frontmatter.author && <meta name="author" content={frontmatter.author} />}
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" type="application/xml" href={`${url.origin}/sitemap-index.xml`} />
  <link rel="alternate" type="application/rss+xml" title="API Integration Hub" href={`${url.origin}/rss.xml`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:type" content={isContent ? 'article' : 'website'} />
  <meta property="og:title" content={frontmatter.title} />
  <meta property="og:description" content={frontmatter.description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="API Integration Hub" />
  <meta property="og:locale" content="en_US" />
  {frontmatter.lastUpdated && <meta property="article:modified_time" content={new Date(frontmatter.lastUpdated).toISOString()} />}
  {frontmatter.lastUpdated && <meta property="article:published_time" content={new Date(frontmatter.lastUpdated).toISOString()} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@APIIntegrationHub" />
  <meta name="twitter:title" content={frontmatter.title} />
  <meta name="twitter:description" content={frontmatter.description} />
  <meta name="twitter:image" content={ogImage} />

  {isContent && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      headline: frontmatter.title,
      description: frontmatter.description,
      author: { '@type': 'Person', name: frontmatter.author || 'O.M. Binmsaad' },
      dateModified: frontmatter.lastUpdated,
      datePublished: frontmatter.lastUpdated,
      publisher: { '@type': 'Organization', name: 'API Integration Hub' },
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
      url: canonical,
    })} />
  )}
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">
        <span class="site-logo-icon">A</span>
        API Integration Hub
      </a>
      <nav class="site-nav" aria-label="Main">
        <a href="/integrations">Integrations</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <div id="main-content">
    <slot />
  </div>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <strong>API Integration Hub</strong>
          <p>Production-tested troubleshooting guides for SaaS API integration errors. Root cause analysis, detection steps, and copy-paste-ready fixes.</p>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <ul>
            <li><a href="/integrations">Integration Guides</a></li>
            <li><a href="/rss.xml">RSS Feed</a></li>
            <li><a href="/sitemap-index.xml">Sitemap</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/author">Author</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <ul>
            <li><a href="/privacy">Privacy</a></li>
            <li><a href="/terms">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} API Integration Hub. All rights reserved.
      </div>
    </div>
  </footer>
</body>
</html>
