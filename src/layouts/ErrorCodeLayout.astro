---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const { content } = Astro.props;
const { tool, errorCode, errorName, httpStatus, severity, lastUpdated } = content;
const toolDisplay = tool.charAt(0).toUpperCase() + tool.slice(1);
---

<BaseLayout frontmatter={content}>
  <article>
    <Breadcrumb
      segments={[
        { label: toolDisplay, href: `/${tool}` },
        { label: 'Errors', href: `/${tool}/errors` },
        { label: `${errorCode}${errorName ? ' — ' + errorName : ''}` },
      ]}
    />

    <header>
      <h1>{content.title}</h1>
      <dl class="metadata">
        {severity && <div><dt>Severity</dt><dd><span class={`badge badge-${severity}`}>{severity}</span></dd></div>}
        {httpStatus && httpStatus !== 0 && <div><dt>HTTP Status</dt><dd><code>{httpStatus}</code></dd></div>}
        {lastUpdated && <div><dt>Last Updated</dt><dd><time datetime={lastUpdated}>{lastUpdated}</time></dd></div>}
      </dl>
    </header>

    <slot />

    <footer class="related">
      <h2>More {toolDisplay} Errors</h2>
      <a href={`/${tool}/errors`}>&larr; View all {toolDisplay} error codes</a>
    </footer>
  </article>
</BaseLayout>
