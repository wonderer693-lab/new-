---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const { content } = Astro.props;
const { toolA, toolB, integrationSlug, errorSlug, errorName, category, errorType, severity, lastUpdated } = content;
const toolADisplay = toolA.charAt(0).toUpperCase() + toolA.slice(1);
const toolBDisplay = toolB.charAt(0).toUpperCase() + toolB.slice(1);
---

<BaseLayout frontmatter={content}>
  <article>
    <Breadcrumb
      segments={[
        { label: 'Integrations', href: '/integrations' },
        { label: `${toolADisplay} ↔ ${toolBDisplay}`, href: `/integrations/${integrationSlug}` },
        { label: 'Errors' },
        { label: errorName || errorSlug },
      ]}
    />

    {errorType === 'silent-failure' && (
      <div class="urgency-banner">
        <strong>Silent failure:</strong> This error produces no HTTP error code.
        Your data may be wrong right now.
      </div>
    )}

    <header>
      <h1>{content.title}</h1>
      <dl class="metadata">
        {severity && <div><dt>Severity</dt><dd class={`badge badge-${severity}`}>{severity}</dd></div>}
        {category && <div><dt>Category</dt><dd>{category}</dd></div>}
        {errorType && <div><dt>Type</dt><dd>{errorType === 'silent-failure' ? '⚠ Silent failure' : errorType}</dd></div>}
        {lastUpdated && <div><dt>Updated</dt><dd><time datetime={lastUpdated}>{lastUpdated}</time></dd></div>}
      </dl>
    </header>

    <slot />

    <footer class="related">
      <h2>Related</h2>
      <ul>
        <li><a href={`/${toolA}`}>{toolADisplay} API Reference</a></li>
        <li><a href={`/${toolB}`}>{toolBDisplay} API Reference</a></li>
      </ul>
    </footer>
  </article>
</BaseLayout>
