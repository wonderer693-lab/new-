---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const integrations = await getCollection('integrations');
const pairs = [...new Map(integrations.map(e => [e.data.integrationSlug, e.data]))];

const frontmatter = {
  title: 'Integration Error Guides — SaaS API Troubleshooting',
  description: 'Browse all integration error guides for Salesforce, HubSpot, Mailchimp, Slack, Zoho, Pipedrive, ActiveCampaign, Calendly, Make, and Zapier.',
  keywords: ['api integration errors', 'saas integration troubleshooting', 'middleware integration fixes'],
};
---

<BaseLayout {frontmatter}>
  <main>
    <nav aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a><span aria-hidden="true"> / </span></li>
        <li><span>Integrations</span></li>
      </ol>
    </nav>

    <h1>Integration Error Guides</h1>
    <p>Cross-tool integration errors — the silent failure layer most docs don't cover. Each guide includes root cause, detection, and production-ready fixes.</p>

    <div class="tool-grid">
      {pairs.map(([slug, data]) => {
        const count = integrations.filter(e => e.data.integrationSlug === slug).length;
        return (
          <a href={`/integrations/${slug}`} class="tool-card">
            <h3>{data.toolA} ↔ {data.toolB}</h3>
            <p>{count} error{count !== 1 ? 's' : ''}</p>
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>
