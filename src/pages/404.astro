---
import BaseLayout from '../layouts/BaseLayout.astro';
const frontmatter = { title: '404 — Page Not Found | API Integration Hub', description: 'The page you requested does not exist.', noindex: true };
---
<BaseLayout {frontmatter}>
  <main style="text-align: center; padding: 4rem 1.5rem;">
    <p style="font-size: 4rem; font-weight: 800; color: var(--color-text-muted); line-height: 1;">404</p>
    <h1>Page Not Found</h1>
    <p>The page you are looking for does not exist or has been moved.</p>
    <a href="/" style="display: inline-block; margin-top: 1rem; padding: 0.6rem 1.5rem; background: var(--color-primary); color: white; border-radius: var(--radius); font-weight: 600; text-decoration: none;">Back to Home</a>
  </main>
</BaseLayout>
