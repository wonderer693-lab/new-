---
import BaseLayout from '../layouts/BaseLayout.astro';

const frontmatter = {
  title: 'Terms of Service — API Integration Hub',
  description: 'Terms of service for using API Integration Hub. Disclaimer, liability, and acceptable use.',
  noindex: true,
};
---

<BaseLayout {frontmatter}>
  <main>
    <h1>Terms of Service</h1>
    <p><strong>Last updated:</strong> June 29, 2026</p>

    <section>
      <h2>Acceptance of Terms</h2>
      <p>By accessing API Integration Hub ("the Site"), you agree to these Terms of Service. If you do not agree, do not use the Site.</p>
    </section>

    <section>
      <h2>Use of Content</h2>
      <p>The content on this Site is provided for informational and educational purposes. You may:</p>
      <ul>
        <li>Read, copy, and use code examples in your own projects</li>
        <li>Share links to our pages</li>
        <li>Reference our content with attribution</li>
      </ul>
      <p>You may <strong>not</strong>:</p>
      <ul>
        <li>Scrape, crawl, or automate access to the Site without permission</li>
        <li>Republish our content in bulk without attribution</li>
        <li>Use the Site for any illegal purpose</li>
      </ul>
    </section>

    <section>
      <h2>Disclaimer</h2>
      <p>The information on this Site is provided "as is" without warranty of any kind. While we strive for accuracy, we cannot guarantee that all information is current, complete, or error-free.</p>
      <p><strong>Use the code examples and fixes at your own risk.</strong> Always test in a staging environment before deploying to production.</p>
    </section>

    <section>
      <h2>Limitation of Liability</h2>
      <p>API Integration Hub and its contributors are not liable for any damages arising from your use of the Site or reliance on its content, including but not limited to:</p>
      <ul>
        <li>Data loss or corruption</li>
        <li>Service interruptions</li>
        <li>Financial losses</li>
        <li>Security breaches</li>
      </ul>
    </section>

    <section>
      <h2>Third-Party Links</h2>
      <p>The Site may contain links to third-party websites (e.g., official API documentation, Stack Overflow). We are not responsible for the content or privacy practices of these external sites.</p>
    </section>

    <section>
      <h2>Trademarks</h2>
      <p>All product names, logos, and brands mentioned on this Site are property of their respective owners. Our use of these names is for identification purposes only and does not imply endorsement.</p>
      <p>API Integration Hub is not affiliated with, sponsored by, or endorsed by Salesforce, HubSpot, Mailchimp, ActiveCampaign, Pipedrive, Zapier, Make, Zoho, Slack, Calendly, or any other tool we document.</p>
    </section>

    <section>
      <h2>Changes to Terms</h2>
      <p>We may update these Terms from time to time. Changes will be posted on this page with an updated "Last updated" date. Continued use of the Site after changes constitutes acceptance.</p>
    </section>

    <section>
      <h2>Contact</h2>
      <p>For questions about these Terms, visit our <a href="/contact">contact page</a>.</p>
    </section>
  </main>
</BaseLayout>
