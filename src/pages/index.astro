---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const errors = await getCollection('errors');
const integrations = await getCollection('integrations');
const guides = await getCollection('guides');
const tools = [...new Set(errors.map(e => e.data.tool))].sort();
const totalErrors = errors.length;
const totalIntegrations = integrations.length;
const totalGuides = guides.length;

const frontmatter = {
  title: 'API Integration Hub — Error Fixes & Troubleshooting Guides',
  description: 'Production-tested fixes for API integration errors between Salesforce, HubSpot, Mailchimp, ActiveCampaign, Slack, Zoho, Pipedrive, Calendly, Make, and Zapier.',
  keywords: [
    'api integration troubleshooting', 'saas integration error fixes',
    'salesforce api errors', 'hubspot api errors', 'mailchimp integration errors',
  ],
};
---

<BaseLayout {frontmatter}>
  <section class="hero">
    <h1>Fix SaaS API Errors Fast</h1>
    <p>Production-tested troubleshooting guides with root cause analysis, copy-paste-ready code fixes, and prevention strategies for every major integration.</p>
  </section>

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-value">{totalErrors}</div>
      <div class="stat-label">Error Guides</div>
    </div>
    <div class="stat">
      <div class="stat-value">{tools.length}</div>
      <div class="stat-label">Tools Covered</div>
    </div>
    <div class="stat">
      <div class="stat-value">{totalIntegrations}</div>
      <div class="stat-label">Integration Pairs</div>
    </div>
    <div class="stat">
      <div class="stat-value">{totalGuides}</div>
      <div class="stat-label">Migration Guides</div>
    </div>
  </div>

  <div class="content-section">
    <h2>Browse by Tool</h2>
    <div class="tool-grid">
      {tools.map(tool => {
        const toolErrors = errors.filter(e => e.data.tool === tool);
        const toolIntegrations = integrations.filter(e => e.data.toolA === tool || e.data.toolB === tool);
        const displayName = tool.charAt(0).toUpperCase() + tool.slice(1);
        return (
          <a href={`/${tool}`} class="tool-card">
            <h3>{displayName}</h3>
            <div class="tool-card-count">
              <span>{toolErrors.length} errors</span>
              {toolIntegrations.length > 0 && <span>&middot; {toolIntegrations.length} integrations</span>}
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <div class="content-section">
    <h2>Recent Error Guides</h2>
    <ul class="error-list">
      {errors.slice(0, 10).map(e => (
        <li>
          <a href={`/${e.data.tool}/errors/${e.data.errorCode}`}>
            <span class={`badge badge-${e.data.severity}`}>{e.data.severity}</span>
            <span>{e.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="content-section">
    <h2>Integration Error Guides</h2>
    <ul class="error-list">
      {integrations.slice(0, 10).map(e => (
        <li>
          <a href={`/integrations/${e.data.integrationSlug}/errors/${e.data.errorSlug}`}>
            <span class={`badge badge-${e.data.severity}`}>{e.data.severity}</span>
            <span>{e.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
